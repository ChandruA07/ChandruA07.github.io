  // ===========================================================
  //  Daily Progress feed — every Solar/WTG update lands here
  // ===========================================================

  // Session-level progress date: section forms set this (via setProgressDate)
  // so that writes which don't pass an explicit date still land on the chosen
  // day. Cleared back to null (=today) after each form submit.
  let _sessionProgressDate = null;
  function setProgressDate(iso){
    _sessionProgressDate = (iso && /^\d{4}-\d{2}-\d{2}$/.test(iso)) ? iso : null;
  }

  async function pushDailyProgress(entry) {
    // Internal helper: called by renderers after a Solar/WTG/BOP/Land write.
    // Drops a richer log entry on /dailyProgress so the home DPR can show
    // it as a bullet point. In demo mode, anonymous calls are accepted —
    // byName falls back to the demo display name or 'Anonymous'.
    if (!entry.date && _sessionProgressDate) entry = Object.assign({}, entry, { date: _sessionProgressDate });
    const me = auth.current();
    const ref = fbDB.ref('dailyProgress').push();
    // Allow back-dating: if a valid ISO date is supplied, stamp the entry with
    // that day (so progress recorded for a previous date lands on the right
    // day in the dashboard, manpower view and reports). Otherwise use now.
    const customDate = (entry.date && /^\d{4}-\d{2}-\d{2}$/.test(entry.date)) ? entry.date : null;
    const tsForDate = customDate ? (new Date(customDate + 'T12:00:00').getTime()) : fbServerTs;
    const payload = {
      module:  String(entry.module || '').slice(0, 20),
      itc:     entry.itc     ? String(entry.itc).slice(0, 20)     : null,
      turbine: entry.turbine ? String(entry.turbine).slice(0, 20) : null,
      activity: String(entry.act || entry.activity || '').slice(0, 200),
      act:     String(entry.act || entry.activity || '').slice(0, 200),
      sub:     entry.sub   ? String(entry.sub).slice(0, 200) : null,
      val:     entry.val   !== undefined ? Number(entry.val)   || 0 : null,
      pct:     entry.pct   !== undefined ? Number(entry.pct)   || 0 : null,
      today:   entry.today !== undefined ? Number(entry.today) || 0 : null,
      date:    customDate || todayISO(),
      by:      me ? me.uid : 'anon',
      byName:  me ? me.name : 'Anonymous',
      ts:      tsForDate
    };
    await ref.set(payload);
    return { id: ref.key };
  }

  // ===========================================================
  //  Schedule (S-curve)  — admin only
  // ===========================================================

  async function updateSchedule(patch) {
    const me = _u();
    if (!auth.canEdit()) throw new Error('🔒 Login required to edit (use the section credentials, or Site Manager).');
    const updates = {};
    if (Array.isArray(patch.planned)) updates['schedule/planned'] = patch.planned.map(n => Number(n) || 0);
    if (Array.isArray(patch.actual))  updates['schedule/actual']  = patch.actual.map(n => n === null ? null : Number(n) || 0);
    if (Array.isArray(patch.labels))  updates['schedule/labels']  = patch.labels.map(s => String(s).slice(0, 20));
    await fbDB.ref().update(updates);
    _audit('schedule.update', 'schedule', null, patch);
  }

  // ===========================================================
  //  User profile (own name only; never role)
  // ===========================================================

  async function setUserProfile(patch) {
    const me = _u();
    const updates = {};
    if (patch.name)  updates['users/' + me.uid + '/name']  = String(patch.name).slice(0,80);
    if (patch.email) updates['users/' + me.uid + '/email'] = String(patch.email).slice(0,120);
    // role is intentionally absent — rules reject it from non-admins anyway.
    await fbDB.ref().update(updates);
  }

  // ===========================================================
  //  Debounced batched write (used by sliders/spinners)
  // ===========================================================
  // Some UIs (e.g. ITC sub-activity sliders) fire dozens of
  // value-change events as the user drags. Debounce them so we
  // only push one update per ~400ms — much kinder to the free
  // tier quotas.

  const _pending = {};
  let _pendingTimer = null;
  function debouncedUpdate(path, value) {
    _pending[path] = value;
    clearTimeout(_pendingTimer);
    _pendingTimer = setTimeout(() => {
      const u = _pending; Object.keys(u).length && fbDB.ref().update(u).catch(e => console.warn('[dataApi] debouncedUpdate failed:', e));
      Object.keys(_pending).forEach(k => delete _pending[k]);
    }, 400);
  }

  // ===========================================================
  //  DAILY SNAPSHOTS
  // ===========================================================
  // A snapshot captures a compact picture of progress for one calendar
  // day. Stored at /snapshots/{YYYY-MM-DD}. The current day's snapshot is
  // auto-written (debounced) whenever progress changes; past snapshots can
  // be re-saved when a user edits historical data.
  //
  //   snapshot = {
  //     date, savedAt, savedBy,
  //     wtg:  { overall, turbines:{ id:{pct,status,lp,pp} } },
  //     solar:{ overall, itcs:{ id:{pct,pre,install,post} } },
  //     bop:  { overall, b33, b66, pss, gss }
  //   }

  // Build a snapshot object from the CURRENT live DB state.
  function buildSnapshot(dateStr) {
    const date = (dateStr && /^\d{4}-\d{2}-\d{2}$/.test(dateStr)) ? dateStr : todayISO();
    const snap = { date, savedAt: Date.now(), savedBy: _u().uid || 'system' };

    // WTG
    try {
      const turbs = {};
      (DB.wtg && DB.wtg.turbines || []).forEach(t => {
        turbs[t.id] = {
          pct:    (typeof calcTurbProg === 'function') ? calcTurbProg(t) : 0,
          status: t.status || 'pending',
          lp: !!t.lp, pp: !!t.pp
        };
      });
      snap.wtg = {
        overall: (typeof calcWtgProg === 'function') ? calcWtgProg() : 0,
        turbines: turbs
      };
    } catch(e){ snap.wtg = { overall:0, turbines:{} }; }

    // Solar
    try {
      const itcs = {};
      Object.entries(DB.solar && DB.solar.itcs || {}).forEach(([id,d]) => {
        const sp = (typeof solItcActsPct === 'function') ? solItcActsPct(d) : {pre:0,install:0,post:0};
        itcs[id] = {
          pct:     (typeof calcITCProg === 'function') ? calcITCProg(id) : 0,
          pre: sp.pre, install: sp.install, post: sp.post
        };
      });
      snap.solar = {
        overall: (typeof calcSolarProg === 'function') ? calcSolarProg() : 0,
        itcs: itcs
      };
    } catch(e){ snap.solar = { overall:0, itcs:{} }; }

    // BOP
    try {
      snap.bop = {
        overall: (typeof calcBopProg     === 'function') ? calcBopProg()     : 0,
        b33:     (typeof calcBop33PctV2  === 'function') ? calcBop33PctV2()  : 0,
        b66:     (typeof calcBop66PctV2  === 'function') ? calcBop66PctV2()  : 0,
        pss:     (typeof calcPssPct      === 'function') ? calcPssPct()      : 0,
        gss:     (typeof calcGssPct      === 'function') ? calcGssPct()      : 0
      };
    } catch(e){ snap.bop = { overall:0, b33:0, b66:0, pss:0, gss:0 }; }

    return snap;
  }

  // Write a snapshot for a given date (defaults to today). Public — the
  // auto-saver runs without a login so snapshots never get skipped.
  async function saveSnapshot(dateStr) {
    const snap = buildSnapshot(dateStr);
    try {
      await fbDB.ref('snapshots/' + snap.date).set(snap);
    } catch(e){ console.warn('[snapshot] save failed:', e); }
    return snap;
  }

  // Debounced auto-save of TODAY's snapshot — call after any progress change.
  let _snapTimer = null;
  function autoSnapshot() {
    clearTimeout(_snapTimer);
    _snapTimer = setTimeout(() => { saveSnapshot(todayISO()); }, 3000);
  }

  // Fetch one date's snapshot (null if none exists).
  async function getSnapshot(dateStr) {
    try {
      const s = await fbDB.ref('snapshots/' + dateStr).once('value');
      return s.exists() ? s.val() : null;
    } catch(e){ console.warn('[snapshot] get failed:', e); return null; }
  }

  // List the dates that have snapshots (sorted, newest first).
  async function listSnapshotDates() {
    try {
      const s = await fbDB.ref('snapshots').once('value');
      if (!s.exists()) return [];
      return Object.keys(s.val()).sort().reverse();
    } catch(e){ return []; }
  }

  // Save an EDITED historical snapshot (login required for past-date edits).
  async function updateSnapshot(dateStr, snap) {
    if (!auth.canEdit()) throw new Error('🔒 Login required to edit historical data.');
    if (!/^\d{4}-\d{2}-\d{2}$/.test(dateStr)) throw new Error('Bad date');
    snap.date = dateStr;
    snap.savedAt = Date.now();
    snap.savedBy = _u().uid || 'edit';
    snap.edited = true;
    await fbDB.ref('snapshots/' + dateStr).set(snap);
    _audit('snapshot.edit', 'snapshots/' + dateStr, null, { date: dateStr });
  }

  global.dataApi = {
    todayISO,
    buildSnapshot, saveSnapshot, autoSnapshot, getSnapshot,
    listSnapshotDates, updateSnapshot,
    // POD + Daily Progress (PUBLIC — no login required)
    addPod,
    addDailyProgress,
    pushDailyProgress,                      // internal richer log (auth-required, used by renderers)
    setProgressDate,                        // back-dating: set session progress date for forms
    // POD status / remarks / next-day plan / ITC live activities (login required)
    updatePodStatus,
    addNextDayPlan, deleteNextDayPlan,
    updateItcLiveActivities,
    // Solar
    updateSolarAct, updateSolarMeta,
    // WTG
    updateTurbine,
    setZeroPoint,
    setWtgCustomActs,
    setWtgKpiOverrides,
    setSolarItc,
    setSolarCustomActs,
    // BOP — all four sub-sections
    updateBopAct, updateBopFeeder, updateBop66Act, updateBop33Poles, updateBop33Line, updatePssAct, updateGssAct,
    // HSE
    addHseObservation, updateHseObservation, deleteHseObservation,
    addHseEmployee,    updateHseEmployee,    deleteHseEmployee,
    // Land
    updateWtgLand, updateSolLand, addLandParcel, updateLandParcel,
    addSolLease, removeSolLease,
    // Lists
    addBlocker,
    addMilestone, updateMilestone, deleteMilestone,
    addRowIssue, updateRowIssue, deleteRowIssue,
    // Admin-only
    setGanttRows,
    updateSchedule,
    setUserProfile,
    debouncedUpdate,
    notify: _notify
  };

})(window);


// ═══════════════════════════════════════════════════════════════
//  data-api.js — EXTENSION BLOCK (v11 "firebase-hardening")
//
//  New modules: Vendors, Purchase Orders, Inventory (append-only
//  ledger), Planning (tasks + baselines + reverse dependency
//  index), Documents (Storage-backed, versioned metadata).
//
//  Every mutator here follows the SAME contract as the block above:
//    • leaf-level fbDB.ref().update({...}) — never parent .set()
//    • push() keys for growing lists
//    • lastBy / lastAt (or by / ts) stamped on every write
//    • _audit() + _notify() on every mutation
//    • basic input validation (required fields, numeric ranges,
//      date sanity) BEFORE anything touches the wire
//
//  RTDB tree added by this block (full reference in
//  docs/FIREBASE-TREE.md):
//
//    /vendors/{vendorId}                     vendor master
//    /purchaseOrders/{poId}                  header (denormalized vendorName)
//    /purchaseOrders/{poId}/lineItems/{id}
//    /inventory/items/{itemId}               item master (minStock for alerts)
//    /inventory/movements/{YYYY-MM-DD}/{pushId}   APPEND-ONLY ledger
//    /planning/tasks/{taskId}                predecessorIds: {taskId:true}
//    /planning/dependents/{taskId}/{depId}   REVERSE index (maintained here)
//    /planning/baselines/{taskId}            frozen {start,end} pairs
//    /documents/{docId}                      metadata only; files in Storage
//    /documents/{docId}/versions/{verId}
// ═══════════════════════════════════════════════════════════════

(function (global) {

  const api = global.dataApi;
  if (!api) { console.error('[data-ext] dataApi missing — load order broken'); return; }

  function _me() {
    const p = (global.auth && auth.current && auth.current()) || null;
    return p || { uid: 'anon', name: 'Anonymous', role: 'viewer' };
  }
  function _need(section) {
    // Same gate style as the core block: section credentials or admin.
    if (!(global.auth && auth.canEdit && auth.canEdit(section))) {
      throw new Error('🔒 Login required — use the ' + (section || 'section') + ' credentials, or Site Manager.');
    }
  }
  function _audit2(action, path, before, after) {
    try {
      const me = _me();
      fbDB.ref('audit/' + Date.now() + '_' + Math.random().toString(36).slice(2, 7)).set({
        uid: me.uid, role: me.role || '?', action, path,
        before: before === undefined ? null : before,
        after:  after  === undefined ? null : after,
        ts: fbServerTs
      }).catch(() => {});
    } catch (e) {}
  }
  const _notify2 = api.notify || function () {};
  function _safeKey(s) { return String(s).replace(/[.#$\[\]\/]/g, '_'); }
  function _isISO(d) { return /^\d{4}-\d{2}-\d{2}$/.test(String(d || '')); }
  function _reqStr(v, label, max) {
    v = String(v == null ? '' : v).trim();
    if (!v) throw new Error(label + ' is required.');
    return v.slice(0, max || 200);
  }
  function _num(v, label, min, max) {
    const n = Number(v);
    if (!isFinite(n)) throw new Error(label + ' must be a number.');
    if (min !== undefined && n < min) throw new Error(label + ' must be ≥ ' + min);
    if (max !== undefined && n > max) throw new Error(label + ' must be ≤ ' + max);
    return n;
  }

  // ─────────────────────────────────────────────────────────────
  //  VENDORS  —  /vendors/{vendorId}
  // ─────────────────────────────────────────────────────────────
  async function addVendor(v) {
    _need('procurement'); const me = _me();
    const ref = fbDB.ref('vendors').push();
    const payload = {
      name:     _reqStr(v.name, 'Vendor name', 120),
      category: _reqStr(v.category || 'General', 'Category', 60),
      contact:  String(v.contact || '').slice(0, 120),
      phone:    String(v.phone   || '').slice(0, 30),
      email:    String(v.email   || '').slice(0, 120),
      gstin:    String(v.gstin   || '').slice(0, 20),
      address:  String(v.address || '').slice(0, 300),
      rating:   Math.max(0, Math.min(5, Number(v.rating) || 0)),
      status:   'active',
      by: me.uid, byName: me.name, ts: fbServerTs
    };
    if (payload.email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(payload.email)) throw new Error('Invalid email address.');
    await ref.set(payload);
    _audit2('vendor.add', 'vendors/' + ref.key, null, { name: payload.name });
    _notify2('procurement', 'Vendor added', payload.name + ' (' + payload.category + ')');
    return { id: ref.key };
  }

  async function updateVendor(id, patch) {
    _need('procurement'); const me = _me();
    if (!id) throw new Error('vendor id required');
    const base = 'vendors/' + _safeKey(id) + '/';
    const updates = {};
    ['name','category','contact','phone','email','gstin','address','status'].forEach(k => {
      if (patch[k] !== undefined) updates[base + k] = String(patch[k]).slice(0, 300);
    });
    if (patch.rating !== undefined) updates[base + 'rating'] = Math.max(0, Math.min(5, Number(patch.rating) || 0));
    if (!Object.keys(updates).length) return;
    updates[base + 'lastBy'] = me.uid;
    updates[base + 'lastAt'] = fbServerTs;
    await fbDB.ref().update(updates);
    _audit2('vendor.update', base, null, patch);
  }

  // Soft-archive; PO history references stay intact (denormalized vendorName).
  async function archiveVendor(id) { return updateVendor(id, { status: 'archived' }); }

  // ─────────────────────────────────────────────────────────────
  //  PURCHASE ORDERS  —  /purchaseOrders/{poId}
  //
  //  Status workflow (enforced here AND in database.rules.json):
  //      draft → approved → delivered → closed   (+ any → cancelled)
  //  vendorName is DENORMALIZED into the PO header on purpose:
  //  RTDB has no joins, so the PO table renders without a per-row
  //  vendor lookup. If a vendor is renamed, historical POs keep
  //  the name that was current at PO time — which is also the
  //  commercially correct behaviour for a PO document.
  // ─────────────────────────────────────────────────────────────
  const PO_FLOW = { draft: ['approved', 'cancelled'], approved: ['delivered', 'cancelled'], delivered: ['closed'], closed: [], cancelled: [] };

  async function createPO(po) {
    _need('procurement'); const me = _me();
    const vendorId = _reqStr(po.vendorId, 'Vendor', 100);
    const vSnap = await fbDB.ref('vendors/' + _safeKey(vendorId)).once('value');
    if (!vSnap.exists()) throw new Error('Vendor not found.');
    const vendor = vSnap.val();
    if (vendor.status === 'archived') throw new Error('Vendor is archived — reactivate before raising a PO.');
    if (po.expectedDate && !_isISO(po.expectedDate)) throw new Error('Expected date must be YYYY-MM-DD.');
    const ref = fbDB.ref('purchaseOrders').push();
    const payload = {
      poNumber:    _reqStr(po.poNumber || ('PO-' + new Date().getFullYear() + '-' + ref.key.slice(-5).toUpperCase()), 'PO number', 40),
      vendorId,
      vendorName:  vendor.name || '?',           // denormalized — see header note
      module:      String(po.module || 'general').toLowerCase(),
      description: String(po.description || '').slice(0, 500),
      expectedDate: po.expectedDate || null,
      currency:    'INR',
      totalValue:  _num(po.totalValue || 0, 'Total value', 0),
      status:      'draft',
      attachmentURL: po.attachmentURL ? String(po.attachmentURL) : null,
      by: me.uid, byName: me.name, ts: fbServerTs,
      history: { [Date.now() + '_' + Math.random().toString(36).slice(2, 6)]: { ts: Date.now(), status: 'draft', by: me.uid, byName: me.name } }
    };
    await ref.set(payload);
    _audit2('po.create', 'purchaseOrders/' + ref.key, null, { poNumber: payload.poNumber, vendor: payload.vendorName });
    _notify2('procurement', 'PO created', payload.poNumber + ' · ' + payload.vendorName);
    return { id: ref.key, poNumber: payload.poNumber };
  }

  async function addPOLineItem(poId, item) {
    _need('procurement'); const me = _me();
    if (!poId) throw new Error('poId required');
    const poRef = fbDB.ref('purchaseOrders/' + _safeKey(poId));
    const st = (await poRef.child('status').once('value')).val();
    if (st !== 'draft') throw new Error('Line items can only be edited while the PO is a draft.');
    const ref = poRef.child('lineItems').push();
    const qty  = _num(item.qty,  'Quantity', 0.0001);
    const rate = _num(item.rate, 'Rate', 0);
    await ref.set({
      itemName: _reqStr(item.itemName, 'Item name', 160),
      itemId:   item.itemId ? _safeKey(item.itemId) : null,   // optional link to /inventory/items
      unit:     String(item.unit || 'nos').slice(0, 20),
      qty, rate, amount: Math.round(qty * rate * 100) / 100,
      by: me.uid, ts: fbServerTs
    });
    // keep header total in sync via transaction (concurrent adders safe)
    await poRef.child('totalValue').transaction(t => Math.round(((Number(t) || 0) + qty * rate) * 100) / 100);
    _audit2('po.item.add', 'purchaseOrders/' + poId + '/lineItems/' + ref.key, null, { itemName: item.itemName, qty, rate });
    return { id: ref.key };
  }

  async function deletePOLineItem(poId, itemId) {
    _need('procurement');
    const poRef = fbDB.ref('purchaseOrders/' + _safeKey(poId));
    const st = (await poRef.child('status').once('value')).val();
    if (st !== 'draft') throw new Error('Line items can only be edited while the PO is a draft.');
    const itRef = poRef.child('lineItems/' + _safeKey(itemId));
    const it = (await itRef.once('value')).val();
    if (!it) return;
    await itRef.remove();
    await poRef.child('totalValue').transaction(t => Math.max(0, Math.round(((Number(t) || 0) - (Number(it.amount) || 0)) * 100) / 100));
    _audit2('po.item.delete', 'purchaseOrders/' + poId + '/lineItems/' + itemId, it, null);
  }

  async function updatePOStatus(poId, nextStatus, note) {
    const me = _me();
    // Approval requires admin; other transitions need procurement (or admin).
    _need(nextStatus === 'approved' ? 'all' : 'procurement');
    const poRef = fbDB.ref('purchaseOrders/' + _safeKey(poId));
    const cur = (await poRef.child('status').once('value')).val();
    if (!cur) throw new Error('PO not found.');
    const allowed = PO_FLOW[cur] || [];
    if (!allowed.includes(nextStatus)) {
      throw new Error('Invalid transition: ' + cur + ' → ' + nextStatus + '. Allowed: ' + (allowed.join(', ') || 'none'));
    }
    const updates = {};
    updates['status'] = nextStatus;
    // Key = ts + random suffix: two transitions inside the same millisecond
    // (e.g. scripted approvals) must never overwrite each other's history row.
    const histKey = Date.now() + '_' + Math.random().toString(36).slice(2, 6);
    updates['history/' + histKey] = { ts: Date.now(), status: nextStatus, by: me.uid, byName: me.name, note: String(note || '').slice(0, 300) };
    updates['lastBy'] = me.uid; updates['lastAt'] = fbServerTs;
    await poRef.update(updates);
    _audit2('po.status', 'purchaseOrders/' + poId, { status: cur }, { status: nextStatus });
    _notify2('procurement', 'PO ' + nextStatus, 'PO moved to ' + nextStatus + (note ? ' · ' + note : ''));
  }

  // ─────────────────────────────────────────────────────────────
  //  INVENTORY — /inventory/items + APPEND-ONLY movements ledger
  //
  //  There is deliberately NO mutable "currentStock" field written
  //  by the client. Stock = Σ(ledger). The renderer computes it
  //  client-side from the movements it has loaded; a maintained-
  //  total node would need a Cloud Function trigger (Blaze plan) —
  //  documented as a scaling path in docs/SCALABILITY.md.
  //  Movements are date-keyed exactly like /pod so history is
  //  cheap to window and two engineers can never overwrite each
  //  other (each movement is its own pushId).
  // ─────────────────────────────────────────────────────────────
  async function addInventoryItem(item) {
    _need('store'); const me = _me();
    const ref = fbDB.ref('inventory/items').push();
    await ref.set({
      name:     _reqStr(item.name, 'Item name', 160),
      category: String(item.category || 'General').slice(0, 60),
      unit:     String(item.unit || 'nos').slice(0, 20),
      minStock: Math.max(0, Number(item.minStock) || 0),   // low-stock alert threshold
      location: String(item.location || 'Main Store').slice(0, 80),
      status:   'active',
      by: me.uid, byName: me.name, ts: fbServerTs
    });
    _audit2('inv.item.add', 'inventory/items/' + ref.key, null, { name: item.name });
    return { id: ref.key };
  }

  async function updateInventoryItem(id, patch) {
    _need('store'); const me = _me();
    const base = 'inventory/items/' + _safeKey(id) + '/';
    const updates = {};
    ['name','category','unit','location','status'].forEach(k => { if (patch[k] !== undefined) updates[base + k] = String(patch[k]).slice(0, 160); });
    if (patch.minStock !== undefined) updates[base + 'minStock'] = Math.max(0, Number(patch.minStock) || 0);
    if (!Object.keys(updates).length) return;
    updates[base + 'lastBy'] = me.uid; updates[base + 'lastAt'] = fbServerTs;
    await fbDB.ref().update(updates);
    _audit2('inv.item.update', base, null, patch);
  }

  /**
   * Append one ledger entry. type: 'in' | 'out' | 'adjust'.
   * qty is always positive; the sign is derived from type
   * ('adjust' may carry negative qty for stocktake corrections).
   */
  async function addStockMovement(mv) {
    _need('store'); const me = _me();
    const itemId = _safeKey(_reqStr(mv.itemId, 'Item', 100));
    const type = String(mv.type || '').toLowerCase();
    if (!['in', 'out', 'adjust'].includes(type)) throw new Error("Movement type must be 'in', 'out' or 'adjust'.");
    let qty = _num(mv.qty, 'Quantity');
    if (type !== 'adjust' && qty <= 0) throw new Error('Quantity must be > 0.');
    const date = _isISO(mv.date) ? mv.date : api.todayISO();
    if (date > api.todayISO()) throw new Error('Movement date cannot be in the future.');
    const ref = fbDB.ref('inventory/movements/' + date).push();
    const payload = {
      itemId, type, qty,
      ref:   String(mv.ref   || '').slice(0, 120),   // PO number / issue slip
      to:    String(mv.to    || '').slice(0, 120),   // consumer / destination
      notes: String(mv.notes || '').slice(0, 300),
      by: me.uid, byName: me.name, ts: fbServerTs
    };
    await ref.set(payload);
    _audit2('inv.move', 'inventory/movements/' + date + '/' + ref.key, null, { itemId, type, qty });
    _notify2('store', 'Stock ' + type, itemId + ' · ' + qty + (mv.ref ? ' · ' + mv.ref : ''));
    return { id: ref.key, date };
  }

  /**
   * Site-to-site transfer = ONE atomic multi-path update writing
   * two ledger rows (out@from, in@to) that succeed or fail together.
   */
  async function recordTransfer(t) {
    _need('store'); const me = _me();
    const itemId = _safeKey(_reqStr(t.itemId, 'Item', 100));
    const qty = _num(t.qty, 'Quantity', 0.0001);
    const from = _reqStr(t.from, 'From location', 80);
    const to   = _reqStr(t.to, 'To location', 80);
    if (from === to) throw new Error('From and To locations must differ.');
    const date = _isISO(t.date) ? t.date : api.todayISO();
    const base = 'inventory/movements/' + date + '/';
    const k1 = fbDB.ref(base).push().key, k2 = fbDB.ref(base).push().key;
    const stamp = { itemId, qty, by: me.uid, byName: me.name, ts: fbServerTs, transferId: k1 };
    await fbDB.ref().update({
      [base + k1]: { ...stamp, type: 'out', ref: 'TRANSFER', to, notes: 'Transfer ' + from + ' → ' + to, location: from },
      [base + k2]: { ...stamp, type: 'in',  ref: 'TRANSFER', to, notes: 'Transfer ' + from + ' → ' + to, location: to }
    });
    _audit2('inv.transfer', base, null, { itemId, qty, from, to });
    _notify2('store', 'Stock transfer', itemId + ' · ' + qty + ' · ' + from + ' → ' + to);
    return { date, outId: k1, inId: k2 };
  }

  // ─────────────────────────────────────────────────────────────
  //  PLANNING — /planning/tasks + reverse dependency index
  //
  //  predecessorIds is stored as a map {taskId:true} (RTDB-friendly
  //  set). Because RTDB cannot query "who depends on X", we also
  //  maintain /planning/dependents/{X}/{taskId}:true in the SAME
  //  atomic update — the reverse index can never drift from the
  //  forward edges.
  // ─────────────────────────────────────────────────────────────
  function _asIdMap(arr) {
    const m = {};
    (Array.isArray(arr) ? arr : Object.keys(arr || {})).forEach(id => { if (id) m[_safeKey(id)] = true; });
    return m;
  }

  async function addPlanTask(t) {
    _need('planner'); const me = _me();
    const name = _reqStr(t.name, 'Task name', 200);
    if (!_isISO(t.start) || !_isISO(t.end)) throw new Error('Start and end dates are required (YYYY-MM-DD).');
    if (t.end < t.start) throw new Error('End date cannot be before start date.');
    const preds = _asIdMap(t.predecessorIds);
    const ref = fbDB.ref('planning/tasks').push();
    const updates = {
      ['planning/tasks/' + ref.key]: {
        name, module: String(t.module || 'general').toLowerCase(),
        start: t.start, end: t.end,
        progress: Math.max(0, Math.min(100, Number(t.progress) || 0)),
        predecessorIds: Object.keys(preds).length ? preds : null,
        by: me.uid, byName: me.name, ts: fbServerTs
      }
    };
    Object.keys(preds).forEach(p => { updates['planning/dependents/' + p + '/' + ref.key] = true; });
    await fbDB.ref().update(updates);
    _audit2('plan.task.add', 'planning/tasks/' + ref.key, null, { name, start: t.start, end: t.end });
    _notify2('planner', 'Task added', name);
    return { id: ref.key };
  }

  async function updatePlanTask(id, patch) {
    _need('planner'); const me = _me();
    id = _safeKey(id);
    const base = 'planning/tasks/' + id + '/';
    const cur = (await fbDB.ref('planning/tasks/' + id).once('value')).val();
    if (!cur) throw new Error('Task not found.');
    const start = patch.start !== undefined ? patch.start : cur.start;
    const end   = patch.end   !== undefined ? patch.end   : cur.end;
    if (!_isISO(start) || !_isISO(end) || end < start) throw new Error('Invalid start/end dates.');
    const updates = {};
    if (patch.name     !== undefined) updates[base + 'name']     = _reqStr(patch.name, 'Task name', 200);
    if (patch.module   !== undefined) updates[base + 'module']   = String(patch.module).toLowerCase();
    if (patch.start    !== undefined) updates[base + 'start']    = patch.start;
    if (patch.end      !== undefined) updates[base + 'end']      = patch.end;
    if (patch.progress !== undefined) updates[base + 'progress'] = Math.max(0, Math.min(100, Number(patch.progress) || 0));
    if (patch.predecessorIds !== undefined) {
      const oldP = Object.keys(cur.predecessorIds || {});
      const newP = _asIdMap(patch.predecessorIds);
      if (newP[id]) throw new Error('A task cannot depend on itself.');
      updates[base + 'predecessorIds'] = Object.keys(newP).length ? newP : null;
      oldP.forEach(p => { if (!newP[p]) updates['planning/dependents/' + p + '/' + id] = null; });
      Object.keys(newP).forEach(p => { updates['planning/dependents/' + p + '/' + id] = true; });
    }
    if (!Object.keys(updates).length) return;
    updates[base + 'lastBy'] = me.uid; updates[base + 'lastAt'] = fbServerTs;
    await fbDB.ref().update(updates);
    _audit2('plan.task.update', base, null, patch);
  }

  async function deletePlanTask(id) {
    _need('planner'); id = _safeKey(id);
    const cur = (await fbDB.ref('planning/tasks/' + id).once('value')).val();
    if (!cur) return;
    const dependents = (await fbDB.ref('planning/dependents/' + id).once('value')).val() || {};
    if (Object.keys(dependents).length) {
      throw new Error('Cannot delete: ' + Object.keys(dependents).length + ' task(s) depend on this one. Re-link them first.');
    }
    const updates = { ['planning/tasks/' + id]: null, ['planning/dependents/' + id]: null, ['planning/baselines/' + id]: null };
    Object.keys(cur.predecessorIds || {}).forEach(p => { updates['planning/dependents/' + p + '/' + id] = null; });
    await fbDB.ref().update(updates);
    _audit2('plan.task.delete', 'planning/tasks/' + id, cur, null);
  }

  /** Freeze the current start/end of EVERY task as the baseline (admin). */
  async function setPlanBaseline() {
    _need('all'); const me = _me();
    const snap = (await fbDB.ref('planning/tasks').once('value')).val() || {};
    const updates = {};
    Object.entries(snap).forEach(([id, t]) => {
      updates['planning/baselines/' + id] = { start: t.start, end: t.end, setBy: me.uid, setAt: fbServerTs };
    });
    if (!Object.keys(updates).length) throw new Error('No tasks to baseline.');
    await fbDB.ref().update(updates);
    _audit2('plan.baseline.set', 'planning/baselines', null, { count: Object.keys(updates).length });
    _notify2('planner', 'Baseline saved', Object.keys(updates).length + ' tasks frozen as baseline');
  }

  // ─────────────────────────────────────────────────────────────
  //  DOCUMENTS — metadata in RTDB, binaries in Firebase Storage
  // ─────────────────────────────────────────────────────────────
  async function addDocument(doc) {
    _need(); const me = _me();   // any signed-in role may file documents
    const ref = fbDB.ref('documents').push();
    const v1 = ref.child('versions').push().key;
    await ref.set({
      title:    _reqStr(doc.title, 'Document title', 200),
      category: String(doc.category || 'General').slice(0, 60),
      module:   String(doc.module || 'general').toLowerCase(),
      currentVersion: v1,
      status: 'active',
      by: me.uid, byName: me.name, ts: fbServerTs,
      versions: {
        [v1]: {
          fileURL: _reqStr(doc.fileURL, 'File URL', 2000),
          fileName: String(doc.fileName || 'file').slice(0, 200),
          size: Number(doc.size) || 0, note: String(doc.note || 'Initial upload').slice(0, 300),
          by: me.uid, byName: me.name, ts: fbServerTs
        }
      }
    });
    _audit2('doc.add', 'documents/' + ref.key, null, { title: doc.title });
    _notify2('general', 'Document filed', doc.title);
    return { id: ref.key, versionId: v1 };
  }

  async function addDocumentVersion(docId, ver) {
    _need(); const me = _me();
    docId = _safeKey(docId);
    const dRef = fbDB.ref('documents/' + docId);
    if (!(await dRef.child('title').once('value')).exists()) throw new Error('Document not found.');
    const vId = dRef.child('versions').push().key;
    await fbDB.ref().update({
      ['documents/' + docId + '/versions/' + vId]: {
        fileURL: _reqStr(ver.fileURL, 'File URL', 2000),
        fileName: String(ver.fileName || 'file').slice(0, 200),
        size: Number(ver.size) || 0, note: String(ver.note || '').slice(0, 300),
        by: me.uid, byName: me.name, ts: fbServerTs
      },
      ['documents/' + docId + '/currentVersion']: vId,
      ['documents/' + docId + '/lastBy']: me.uid,
      ['documents/' + docId + '/lastAt']: fbServerTs
    });
    _audit2('doc.version.add', 'documents/' + docId + '/versions/' + vId, null, { fileName: ver.fileName });
    return { versionId: vId };
  }

  async function archiveDocument(docId) {
    _need('all'); const me = _me();
    await fbDB.ref().update({
      ['documents/' + _safeKey(docId) + '/status']: 'archived',
      ['documents/' + _safeKey(docId) + '/lastBy']: me.uid,
      ['documents/' + _safeKey(docId) + '/lastAt']: fbServerTs
    });
    _audit2('doc.archive', 'documents/' + docId, null, { status: 'archived' });
  }

  Object.assign(api, {
    // Procurement & vendors
    addVendor, updateVendor, archiveVendor,
    createPO, addPOLineItem, deletePOLineItem, updatePOStatus,
    PO_FLOW,
    // Inventory
    addInventoryItem, updateInventoryItem, addStockMovement, recordTransfer,
    // Planning
    addPlanTask, updatePlanTask, deletePlanTask, setPlanBaseline,
    // Documents
    addDocument, addDocumentVersion, archiveDocument
  });

})(window);
